PORT=3000
NODE_ENV=development
API_KEY=your-api-key
BROADCAST_DELAY_MS=1500

# Optional — External PostgreSQL session persistence
# When set, WhatsApp sessions survive server restarts and redeployments.
# The required table (wwebjs_sessions) is created automatically on first run.
# Supported: Supabase, Aiven, Neon, Railway, or any standard PostgreSQL instance.
# Leave unset to use local filesystem storage (default).
#
# POSTGRES_URL=postgresql://user:password@host:5432/database
